# Configuración del Servidor
PORT=3000

# Base de Datos MongoDB (usar MongoDB Atlas para producción)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/propinas

# Telegram Bot Configuration
BOT_TOKEN=tu_bot_token_aqui
CHAT_ID=tu_chat_id_aqui

# Configuración del Recordatorio Diario (hora en formato 24h)
CRON_HOUR=23

# HuggingFace API Key (opcional, no se usa con REGEX)
HUGGINGFACE_API_KEY=hf_tu-api-key-aqui

# Entorno de producción
NODE_ENV=production
